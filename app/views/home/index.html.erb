<div class="bg-gray-950 text-white min-h-screen">

  <section class="relative overflow-hidden py-24 px-4 sm:px-6 lg:px-8 text-center">
    <%# Subtle background texture via a faint image %>
    <div class="absolute inset-0 z-0 opacity-20">
      <img class="object-cover w-full h-full" src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1600&auto=format&fit=crop&q=60" alt="">
      <div class="absolute inset-0 bg-gradient-to-b from-gray-950/60 via-transparent to-gray-950"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white mb-6 leading-tight">
        Stories worth<br>
        <span class="text-blue-400">reading.</span>
      </h1>
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        Blogapp is a community of writers and readers. Browse blogs, discover ideas, and share your own perspective with the world.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <%= link_to "Browse all blogs", blogs_path, class: "px-7 py-3.5 rounded-xl font-semibold text-base text-white bg-blue-600 hover:bg-blue-500 transition duration-150 focus:outline-none focus:ring-4 focus:ring-blue-800" %>
        <% if user_signed_in? %>
          <%= link_to "Create your blog", new_blog_path, class: "px-7 py-3.5 rounded-xl font-semibold text-base text-gray-300 bg-gray-800 hover:bg-gray-700 border border-gray-700 transition duration-150" %>
        <% else %>
          <%= link_to "Sign up free", new_user_registration_path, class: "px-7 py-3.5 rounded-xl font-semibold text-base text-gray-300 bg-gray-800 hover:bg-gray-700 border border-gray-700 transition duration-150" %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="border-y border-gray-800 bg-gray-900/50">
    <div class="max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8 grid grid-cols-3 divide-x divide-gray-800 text-center">
      <div class="px-4">
        <p class="text-4xl font-extrabold text-white"><%= number_with_delimiter(@stats[:blogs]) %></p>
        <p class="mt-1 text-sm text-gray-400 uppercase tracking-wide">Published blogs</p>
      </div>
      <div class="px-4">
        <p class="text-4xl font-extrabold text-white"><%= number_with_delimiter(@stats[:posts]) %></p>
        <p class="mt-1 text-sm text-gray-400 uppercase tracking-wide">Posts written</p>
      </div>
      <div class="px-4">
        <p class="text-4xl font-extrabold text-white"><%= number_with_delimiter(@stats[:members]) %></p>
        <p class="mt-1 text-sm text-gray-400 uppercase tracking-wide">Community members</p>
      </div>
    </div>
  </section>

  <section class="max-w-screen-xl mx-auto py-20 px-4 sm:px-6 lg:px-8">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-bold text-white">Featured blogs</h2>
        <p class="mt-1 text-gray-400">Popular reads from our community</p>
      </div>
      <%= link_to "See all", blogs_path, class: "text-sm font-medium text-blue-400 hover:text-blue-300 transition" %>
    </div>

    <% if @featured_blogs.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @featured_blogs.each do |blog| %>
          <%= render 'blogs/blog_card', blog: blog %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-gray-900 border border-gray-800 rounded-xl max-w-lg mx-auto">
        <p class="text-gray-400 mb-4">No blogs have been published yet.</p>
        <% if user_signed_in? %>
          <%= link_to "Create the first one", new_blog_path, class: "px-5 py-2.5 rounded-lg text-sm font-medium text-white bg-blue-600 hover:bg-blue-500 transition" %>
        <% else %>
          <%= link_to "Sign up to get started", new_user_registration_path, class: "px-5 py-2.5 rounded-lg text-sm font-medium text-white bg-blue-600 hover:bg-blue-500 transition" %>
        <% end %>
      </div>
    <% end %>
  </section>


  <footer class="border-t border-gray-800 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-screen-xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center space-x-2">
        <%= appIcon %>
        <span class="font-semibold text-white">Blogapp</span>
      </div>
      <p class="text-xs text-gray-600">&copy; <%= Time.current.year %> Blogapp. All rights reserved.</p>
    </div>
  </footer>

</div>

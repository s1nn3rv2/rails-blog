<div class="z-[999] hidden absolute bg-black bg-opacity-50 flex flex items-center justify-center min-w-full min-h-screen z-50"
     data-controller="modal" id="<%= locals[:id] %>" data-action="click->modal#clickedModal">
  <div id="modal-content" tabindex="-1" class="overflow-y-auto overflow-x-hidden justify-center items-center md:inset-0">
    <%= render locals[:content] %>
  </div>
</div>
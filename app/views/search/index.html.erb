<div class="bg-gray-900 text-white min-h-screen">
  <div class="container mx-auto px-4 py-8 md:py-12">
    <div class="flex flex-col gap-8">
      <div class="flex justify-between items-center">
        <div>
          <h2 class="text-2xl font-bold">Search results for "<%= params[:key] %>"</h2>
          <p class="text-gray-400">Showing <%= @blogs.count %> results</p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% @blogs.each do |blog| %>
          <div class="bg-gray-900 rounded-md overflow-hidden shadow-md">
            <%= link_to blog_path(blog) do %>
              <% if blog.background.present? %>
                <%= image_tag blog.background, class: 'w-full h-40 object-cover' if blog.background.present? %>
              <% end %>
              <div class="p-4">
                <h3 class="text-lg font-semibold mb-2"><%= blog.name %></h3>
                <p class="text-gray-400 line-clamp-2">
                  <%= blog.description %>
                </p>
                <div class="mt-4 text-sm text-gray-400">Last updated at <%= blog?.last_updated_at.strftime('%F') %></div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
    <div class="flex justify-center mt-8">
      <% if @blogs.count > 0 %>
        <nav aria-label="Page navigation example">
          <ul class="flex items-center -space-x-px h-10 text-base">
            <%
              current_page = 'flex items-center justify-center px-4 h-10 leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 bg-blue-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-blue-700 dark:hover:text-white'
              non_current_page = 'flex items-center justify-center px-4 h-10 leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white'
              cur_page = params[:page].present? ? params[:page].to_i : 1
              next_page = cur_page < @pages_count ? cur_page+1 : cur_page
              prev_page = cur_page <= 1 ? cur_page : cur_page-1
            %>
            <li>
              <%= link_to search_results_path(key: params[:key], page: prev_page), class: 'flex items-center justify-center px-4 h-10 ms-0 leading-tight text-gray-500 bg-white border border-e-0 border-gray-300 rounded-s-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white' do %>
                <span class="sr-only">Previous</span>
                <svg class="w-3 h-3 rtl:rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 1 1 5l4 4"/>
                </svg>
              <% end %>
            </li>
            <% (1..@pages_count).each do |page| %>
              <li>
                <%= link_to "#{page}", search_results_path(key: params[:key], page: page), class: "#{page == cur_page ? current_page : non_current_page}" %>
              </li>
            <% end %>
            <li>
              <%= link_to search_results_path(key: params[:key], page: next_page), class: 'flex items-center justify-center px-4 h-10 ms-0 leading-tight text-gray-500 bg-white border border-e-0 border-gray-300 rounded-s-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white' do %>
                <span class="sr-only">Next</span>
                <svg class="w-3 h-3 rtl:rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
                </svg>
              <% end %>
            </li>
          </ul>
        </nav>
      <% end %>
    </div>
  </div>
</div>
